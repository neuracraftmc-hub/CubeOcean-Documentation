---
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import TableOfContents from '../components/TableOfContents.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  headings?: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
  currentLang?: 'en' | 'id';
  currentPage?: string;
  currentSlug?: string;
  siteTitle?: string;
}

const { 
  title, 
  description = '',
  headings = [],
  currentLang = 'en',
  currentPage = '',
  currentSlug = 'introduction',
  siteTitle = 'CubeOcean Cloud'
} = Astro.props;

// Get current date for last updated
const lastUpdated = new Date().toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<!doctype html>
<html lang={currentLang} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} | {siteTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Header currentLang={currentLang} title={siteTitle} currentSlug={currentSlug} />
    
    <div class="layout-wrapper">
      <Sidebar currentLang={currentLang} currentPage={currentPage} />
      
      <main class="main-content">
        <article class="content">
          <Breadcrumb currentLang={currentLang} currentSlug={currentSlug} />
          <slot />
          <footer class="content-footer">
            <p class="last-updated">
              Last updated: <time>{lastUpdated}</time>
            </p>
          </footer>
        </article>
      </main>

      {headings.length > 0 && (
        <TableOfContents headings={headings} currentLang={currentLang} />
      )}
    </div>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  .layout-wrapper {
    display: flex;
    max-width: 100%;
    margin: 0 auto;
    min-height: calc(100vh - 100px);
    background: #f8f9fa;
  }

  html[data-theme="dark"] .layout-wrapper {
    background: #0a0a0a;
  }

  .main-content {
    flex: 1;
    min-width: 0;
    max-width: 850px;
    padding: 0 3rem;
  }

  .content {
    padding: 3.5rem 0;
    overflow-y: auto;
    height: calc(100vh - 100px);
  }

  .content > :first-child {
    margin-top: 0;
  }

  .content-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(59, 130, 246, 0.15);
    text-align: center;
  }

  .last-updated {
    font-size: 0.85rem;
    color: var(--color-text);
    opacity: 0.6;
    margin: 0;
  }

  .last-updated time {
    font-weight: 500;
    opacity: 0.8;
  }

  @media (max-width: 1400px) {
    .main-content {
      padding: 0 2.5rem;
      max-width: 820px;
    }

    .content {
      padding: 3rem 0;
    }
  }

  @media (max-width: 1200px) {
    .layout-wrapper {
      max-width: 100%;
    }

    .main-content {
      padding: 0 2rem;
      max-width: 750px;
    }

    .content {
      padding: 2.5rem 0;
    }
  }

  @media (max-width: 768px) {
    .layout-wrapper {
      flex-direction: column;
    }

    .main-content {
      max-width: 100%;
      order: 2;
      padding: 0 1.5rem;
    }

    .content {
      padding: 1.5rem 0;
      height: auto;
    }
  }
</style>
