---
import { navigation } from '../utils/navigation';

interface Props {
  currentLang: 'en' | 'id';
  currentPage?: string;
}

const { currentLang, currentPage } = Astro.props;
const nav = navigation[currentLang];
---

<aside class="sidebar">
  <nav class="nav">
    {nav.map((section) => (
      <div class="nav-section" key={section.title}>
        <h3 class="nav-section-title">{section.title}</h3>
        <ul class="nav-list">
          {section.items.map((item) => (
            <li key={item.href}>
              <a 
                href={item.href}
                class={`nav-link ${currentPage === item.href ? 'active' : ''}`}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>
</aside>

<style>
  .sidebar {
    width: 280px;
    background: linear-gradient(180deg, rgba(248, 249, 250, 0.5), rgba(240, 241, 245, 0.3));
    border-right: 1px solid rgba(59, 130, 246, 0.2);
    padding: 3rem 1.75rem 2rem;
    height: calc(100vh - 100px);
    overflow-y: auto;
    position: sticky;
    top: 100px;
    flex-shrink: 0;
    transition: background-color 0.3s;
    animation: slideInUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) backwards;
  }

  html[data-theme="dark"] .sidebar {
    background: linear-gradient(180deg, rgba(15, 15, 15, 0.6), rgba(10, 10, 10, 0.8));
  }

  .nav {
    display: flex;
    flex-direction: column;
    gap: 2.2rem;
  }

  .nav-section-title {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    margin-bottom: 0.9rem;
    color: var(--color-text);
    opacity: 0.5;
    margin: 0;
    transition: opacity 0.3s;
  }

  .nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .nav-link {
    display: block;
    padding: 0.6rem 0;
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 400;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    transition: all 0.25s cubic-bezier(0.23, 1, 0.32, 1);
    position: relative;
    text-decoration: none;
    opacity: 0.7;
    line-height: 1.5;
    border-bottom: 2px solid transparent;
    padding-bottom: 0.5rem;
  }

  .nav-link:hover {
    color: var(--color-blue-light);
    opacity: 0.9;
    padding-left: 0.2rem;
    transform: translateY(-2px);
  }

  .nav-link.active {
    color: var(--color-blue);
    font-weight: 500;
    opacity: 1;
    border-bottom-color: var(--color-blue);
    padding-bottom: 0.5rem;
  }

  @keyframes slideInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .sidebar::-webkit-scrollbar {
    width: 6px;
  }

  .sidebar::-webkit-scrollbar-track {
    background: transparent;
  }

  .sidebar::-webkit-scrollbar-thumb {
    background: rgba(59, 130, 246, 0.3);
    border-radius: 3px;
    transition: background 0.3s;
  }

  .sidebar::-webkit-scrollbar-thumb:hover {
    background: var(--color-blue-light);
  }

  @media (max-width: 1200px) {
    .sidebar {
      width: 260px;
      padding: 2.5rem 1.5rem 1.5rem;
    }

    .nav {
      gap: 1.8rem;
    }

    .nav-list {
      gap: 0.35rem;
    }

    .nav-link {
      padding: 0.6rem 0.85rem;
      font-size: 0.85rem;
    }
  }

  @media (max-width: 768px) {
    .sidebar {
      display: none;
    }
  }
</style>

